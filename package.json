{
  "name": "hexguard-repo",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "angular:install": "pnpm --dir angular install",
    "angular:start": "pnpm --dir angular start",
    "angular:demo:snippets": "pnpm --dir angular demo:snippets",
    "angular:watch": "pnpm --dir angular watch",
    "angular:build": "pnpm --dir angular build",
    "angular:build:lib": "pnpm --dir angular build:lib",
    "angular:build:lib:url-state": "pnpm --dir angular build:lib:url-state",
    "angular:build:lib:query-form": "pnpm --dir angular build:lib:query-form",
    "angular:build:demo": "pnpm --dir angular build:demo",
    "angular:test": "pnpm --dir angular test",
    "angular:test:lib": "pnpm --dir angular test:lib",
    "angular:test:lib:url-state": "pnpm --dir angular test:lib:url-state",
    "angular:test:lib:query-form": "pnpm --dir angular test:lib:query-form",
    "angular:test:app": "pnpm --dir angular test:app",
    "angular:test:e2e": "pnpm --dir angular test:e2e",
    "angular:test:e2e:headed": "pnpm --dir angular test:e2e:headed",
    "angular:test:e2e:debug": "pnpm --dir angular test:e2e:debug",
    "angular:test:e2e:install": "pnpm --dir angular test:e2e:install",
    "angular:test:ci": "pnpm --dir angular test:ci",
    "angular:lint": "pnpm --dir angular lint",
    "angular:verify:package": "pnpm --dir angular verify:package",
    "angular:verify:package:url-state": "pnpm --dir angular verify:package:url-state",
    "angular:verify:package:query-form": "pnpm --dir angular verify:package:query-form",
    "start": "pnpm angular:start",
    "demo:snippets": "pnpm angular:demo:snippets",
    "watch": "pnpm angular:watch",
    "build": "pnpm angular:build",
    "build:lib": "pnpm angular:build:lib",
    "build:lib:url-state": "pnpm angular:build:lib:url-state",
    "build:lib:query-form": "pnpm angular:build:lib:query-form",
    "build:demo": "pnpm angular:build:demo",
    "test": "pnpm angular:test",
    "test:lib": "pnpm angular:test:lib",
    "test:lib:url-state": "pnpm angular:test:lib:url-state",
    "test:lib:query-form": "pnpm angular:test:lib:query-form",
    "test:app": "pnpm angular:test:app",
    "test:e2e": "pnpm angular:test:e2e",
    "test:e2e:headed": "pnpm angular:test:e2e:headed",
    "test:e2e:debug": "pnpm angular:test:e2e:debug",
    "test:e2e:install": "pnpm angular:test:e2e:install",
    "test:ci": "pnpm angular:test:ci",
    "lint": "pnpm angular:lint",
    "verify:package": "pnpm angular:verify:package",
    "verify:package:url-state": "pnpm angular:verify:package:url-state",
    "verify:package:query-form": "pnpm angular:verify:package:query-form",
    "dotnet:restore": "dotnet restore dotnet/HexGuard.slnx",
    "dotnet:build": "dotnet build dotnet/HexGuard.slnx --configuration Release",
    "dotnet:test": "dotnet test dotnet/HexGuard.slnx --configuration Release",
    "validate:angular": "pnpm lint && pnpm test:ci && pnpm test:e2e && pnpm build && pnpm verify:package",
    "validate:dotnet": "pnpm dotnet:restore && pnpm dotnet:build && pnpm dotnet:test",
    "validate": "pnpm format:check && pnpm validate:angular && pnpm validate:dotnet"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
