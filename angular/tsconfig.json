/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@hexguard/angular-async-state": ["./packages/angular-async-state/src/public-api.ts"],
      "@hexguard/angular-permissions": ["./packages/angular-permissions/src/public-api.ts"],
      "@hexguard/angular-query-form": ["./packages/angular-query-form/src/public-api.ts"],
      "@hexguard/angular-url-state": ["./packages/angular-url-state/src/public-api.ts"]
    },
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [],
  "references": [
    {
      "path": "./packages/angular-url-state/tsconfig.lib.json"
    },
    {
      "path": "./packages/angular-url-state/tsconfig.spec.json"
    },
    {
      "path": "./packages/angular-query-form/tsconfig.lib.json"
    },
    {
      "path": "./packages/angular-query-form/tsconfig.spec.json"
    },
    {
      "path": "./packages/angular-async-state/tsconfig.lib.json"
    },
    {
      "path": "./packages/angular-async-state/tsconfig.spec.json"
    },
    {
      "path": "./packages/angular-permissions/tsconfig.lib.json"
    },
    {
      "path": "./packages/angular-permissions/tsconfig.spec.json"
    },
    {
      "path": "./apps/demo-angular/tsconfig.app.json"
    },
    {
      "path": "./apps/demo-angular/tsconfig.spec.json"
    }
  ]
}
