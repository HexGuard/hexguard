{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "analytics": false
  },
  "newProjectRoot": "packages",
  "projects": {
    "angular-url-state": {
      "projectType": "library",
      "root": "packages/angular-url-state",
      "sourceRoot": "packages/angular-url-state/src",
      "prefix": "hexguard",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "packages/angular-url-state/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "packages/angular-url-state/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "packages/angular-url-state/tsconfig.spec.json"
          }
        }
      }
    },
    "demo-angular": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/demo-angular",
      "sourceRoot": "apps/demo-angular/src",
      "prefix": "demo",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "apps/demo-angular/src/main.ts",
            "tsConfig": "apps/demo-angular/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/demo-angular/public"
              }
            ],
            "styles": ["apps/demo-angular/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "demo-angular:build:production"
            },
            "development": {
              "buildTarget": "demo-angular:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
